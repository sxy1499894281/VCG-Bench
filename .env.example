# VCG-Bench environment variables
# Copy this file to .env and fill in your own keys.

# OpenAI-compatible VLM endpoint. This is the default provider used by scripts.
CUSTOM_API_KEY=your_api_key_here
CUSTOM_BASE_URL=https://your-endpoint/v1
CUSTOM_VISION_MODEL=gemini-3-pro-preview

# Optional: judge model for SCS/CodeVQA/XDRFR when different from CUSTOM_VISION_MODEL.
# TASK1_JUDGE_MODEL=gemini-3-pro-preview
# TASK2_JUDGE_MODEL=gemini-3-pro-preview

# Optional: SiliconFlow provider.
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_VISION_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# Optional: Zhipu provider.
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_VISION_MODEL=glm-4v

# Optional: local OpenAI-compatible server.
LOCAL_API_KEY=ollama
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_VISION_MODEL=llava

# Optional: Draw.io executable path if auto-detection fails.
# DRAWIO_PATH=/path/to/drawio

# Optional runtime settings.
# LOG_LEVEL=INFO
# DATA_DIR=data
